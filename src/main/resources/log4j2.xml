<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">

    <Properties>
        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%t] %c{1.} - %msg%n
        </Property>

        <Property name="LOG_DIR">${sys:catalina.home}/logs</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <RollingFile
                name="ApplicationFile"
                fileName="${LOG_DIR}/application.log"
                filePattern="${LOG_DIR}/application-%d{yyyy-MM-dd}.log.gz"
                createOnDemand="true">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <RollingFile
                name="RepositoryFile"
                fileName="${LOG_DIR}/repository.log"
                filePattern="${LOG_DIR}/repository-%d{yyyy-MM-dd}.log.gz"
                createOnDemand="true">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <RollingFile
                name="ServiceFile"
                fileName="${LOG_DIR}/service.log"
                filePattern="${LOG_DIR}/service-%d{yyyy-MM-dd}.log.gz"
                createOnDemand="true">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <RollingFile
                name="ControllerFile"
                fileName="${LOG_DIR}/controller.log"
                filePattern="${LOG_DIR}/controller-%d{yyyy-MM-dd}.log.gz"
                createOnDemand="true">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.javarush.zyibin.repository" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RepositoryFile"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin.service" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ServiceFile"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin.controllers" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ControllerFile"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin.filter" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ControllerFile"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin.validation" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin.source" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RepositoryFile"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin.config" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>

        <Logger name="com.javarush.zyibin" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Logger>


        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ApplicationFile"/>
        </Root>
    </Loggers>
</Configuration>




